<node id="Weight Layer">
  <data key="d0">Weight Layer</data>
  <data key="d1">concept</data>
  <data key="d2">A type of trainable neural network layer that applies weight transformations to input signals, appearing twice in the residual path of the residual learning building block.</data>
  <data key="d3">chunk-4fd7f66859f3f10e574d7b4fb7463262</data>
  <data key="d4">ResNet【上】论文精读.mp4</data>
