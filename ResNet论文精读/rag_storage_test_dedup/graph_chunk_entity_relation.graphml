<node id="COCO Dataset">
  <data key="d0">COCO Dataset</data>
  <data key="d1">data</data>
  <data key="d2">The largest and most well-known dataset for target detection tasks in the computer vision field.&lt;SEP&gt;Large, famous object detection dataset, where extremely deep residual networks delivered a 28% relative performance improvement.</data>
  <data key="d3">doc-db198435de3fb87f4348eaba3adebc08-chunk-001&lt;SEP&gt;chunk-dd66735b57b907c822ab1b7be3272894</data>
