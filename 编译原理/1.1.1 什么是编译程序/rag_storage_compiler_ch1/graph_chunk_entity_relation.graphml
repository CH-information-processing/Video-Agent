  <data key="d13"></data>
</edge>
<edge source="Retargetable Compiler" target="Lecturer At Compiler Principles Course">
  <data key="d7">1.0</data>
  <data key="d8">The lecturer is currently explaining the retargetable compiler during the lecture, as indicated by the small red pointer dot on the slide.</data>
  <data key="d9">Explain,introduce</data>
  <data key="d10">chunk-5f5328057af8271fffc25a5e04150084</data>
