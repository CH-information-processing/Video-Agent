  <data key="d6"></data>
</node>
<node id="Machine Language">
  <data key="d0">Machine Language</data>
  <data key="d1">concept</data>
  <data key="d2">Machine language is a low-level programming language consisting of binary instructions that can be directly executed by computers.</data>
  <data key="d3">chunk-524488f325e3b749520b26154058ac49</data>
  <data key="d4">1.1.1 什么是编译程序.mp4</data>
  <data key="d5">1781614961</data>
  <data key="d6"></data>
</node>
<node id="Computer">
  <data key="d0">Computer</data>
  <data key="d1">artifact</data>
  <data key="d2">A computer is an electronic device capable of executing machine language programs.&lt;SEP&gt;The Computer is utilized by the operator and displays a bar chart, indicating application of the translated content.</data>
  <data key="d3">chunk-524488f325e3b749520b26154058ac49&lt;SEP&gt;chunk-d2ab3129aac50b6f07741c4168cd905c</data>
