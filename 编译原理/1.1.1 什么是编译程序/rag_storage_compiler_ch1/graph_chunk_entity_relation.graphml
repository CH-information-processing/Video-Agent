<node id="Source Language">
  <data key="d0">Source Language</data>
  <data key="d1">concept</data>
  <data key="d2">Source language refers to the original programming language in which the initial program is written before translation.</data>
  <data key="d3">chunk-524488f325e3b749520b26154058ac49</data>
