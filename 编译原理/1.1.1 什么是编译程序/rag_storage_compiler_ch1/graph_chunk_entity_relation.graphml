<edge source="Retargetable Compiler" target="Compiler Principles Educational Lecture Slide">
  <data key="d7">1.0</data>
  <data key="d8">The educational slide lists retargetable compiler as one of the four official categories of compilers.</data>
  <data key="d9">List,feature</data>
  <data key="d10">chunk-5f5328057af8271fffc25a5e04150084</data>
