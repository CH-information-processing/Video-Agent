<node id="Original Computer Program">
  <data key="d0">Original Computer Program</data>
  <data key="d1">artifact</data>
  <data key="d2">A high-level program whose individual statements are sequentially translated into machine instructions and executed one by one by the interpreter program to produce the final runtime result.</data>
