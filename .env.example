# VideoScholar / RAG-Anything API configuration
# Copy this file to .env and fill in your real API keys.

# Text / vision model. Volcengine Ark is OpenAI-compatible.
# In Ark, LLM_MODEL and VISION_MODEL may need to be your endpoint id.
LLM_BINDING=openai
LLM_MODEL=Doubao-Seed-2.0-lite
VISION_MODEL=Doubao-Seed-2.0-lite
LLM_BINDING_HOST=https://ark.cn-beijing.volces.com/api/v3
LLM_BINDING_API_KEY=PASTE_ARK_API_KEY_HERE

# Embeddings must be configured separately.
# Doubao-Seed-2.0-lite supports text/image/video input and text output,
# but it does not provide embeddings.
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIM=2048
EMBEDDING_BINDING_HOST=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_BINDING_API_KEY=PASTE_ZHIPU_API_KEY_HERE

ENABLE_LLM_CACHE=true
TIMEOUT=240
TEMPERATURE=0
MAX_ASYNC=4
