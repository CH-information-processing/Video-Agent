# VideoScholar / RAG-Anything API configuration
# Copy this file to .env and fill in your real API keys.

LLM_BINDING=openai
LLM_MODEL=gpt-4.1-2025-04-14
VISION_MODEL=gpt-4.1-2025-04-14
LLM_BINDING_HOST=https://aicore-llm-proxy.internal.cfapps.eu12.hana.ondemand.com/v1
LLM_BINDING_API_KEY=PASTE_YOUR_API_KEY_HERE

EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large-1
EMBEDDING_DIM=3072
EMBEDDING_BINDING_HOST=https://aicore-llm-proxy.internal.cfapps.eu12.hana.ondemand.com/v1
EMBEDDING_BINDING_API_KEY=PASTE_YOUR_API_KEY_HERE

ENABLE_LLM_CACHE=true
TIMEOUT=240
TEMPERATURE=0
MAX_ASYNC=4
